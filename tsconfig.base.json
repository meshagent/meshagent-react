{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2020",
        "lib": ["ES2020", "DOM"],
        "useDefineForClassFields": true,
        "moduleResolution": "node",
        "declaration": true,
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "strict": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",            
        "emitDeclarationOnly": false,
        "baseUrl": "./src",
        "paths": {
            "livekit-client": [
                "../../node_modules/livekit-client/dist/src/index"
            ]
        },
        "rootDir": "./src",
        "typeRoots": [
            "./types",
            "./node_modules/@types",
            "../node_modules/@types"
        ]
    },
    "exclude": [
        "dist"
    ],
    "include": [
        "src"
    ]
}
